{
  "name": "@abhc/spektral-ui",
  "version": "0.3.0",
  "description": "S Svelte 5 design system. Customisable, composable and accessible. WCAG-focused and theme driven. ",
  "license": "GPL-3.0-only",
  "author": "ABHC",
  "homepage": "https://github.com/abhc/spektral-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhc/spektral-ui.git"
  },
  "bugs": {
    "url": "https://github.com/abhc/spektral-ui/issues"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "design-system",
    "ui",
    "components",
    "oklch",
    "tokens",
    "accessibility"
  ],
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/styles/tokens.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.47.1",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.6.0",
    "publint": "^0.3.0",
    "svelte": "^5.41.0",
    "svelte-check": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
